# Live news API keys.
# Copy this file to .env.local and paste your real keys. .env.local is
# gitignored so the keys never end up in the repo.
#
# Get free keys here:
#   NewsAPI:  https://newsapi.org/register           (~100 requests / day on Developer)
#   GNews:    https://gnews.io/register              (~100 requests / day on Free)
#   Currents: https://currentsapi.services/register  (~600 requests / day on Free)
#
# Leave any of these blank to skip that provider. With zero providers
# configured (or if all three fail), the app falls back to the local
# mock articles in /data/articles.json so the demo always works.
#
# These vars are NOT prefixed with NEXT_PUBLIC_, so they stay server-side
# inside the Next.js API routes under /app/api/news/. The keys are never
# shipped to the browser bundle.

NEWSAPI_KEY=
GNEWS_KEY=
CURRENTS_KEY=
